# Toast API Credentials (required)
TOAST_CLIENT_ID=your_client_id_here
TOAST_CLIENT_SECRET=your_client_secret_here

# Toast Restaurant Configuration
# Single restaurant GUID (used if TOAST_RESTAURANT_GUIDS is not set)
TOAST_RESTAURANT_GUID=your_restaurant_guid_here
# Comma separated list for multi location support
# TOAST_RESTAURANT_GUIDS=guid1,guid2,guid3

# Toast API Host (defaults to production)
# TOAST_API_HOST=https://ws-api.toasttab.com

# Safety Controls
# Set to "true" to enable write operations (create/update/cancel orders)
ALLOW_WRITES=false
# Set to "true" to validate write payloads without executing them
DRY_RUN=true

# Logging
LOG_LEVEL=info

# Transport Mode
# "stdio" for local MCP clients (Claude Desktop, Claude Code)
# "http" for cloud deployment (Copilot Studio, Teams SDK, remote clients)
MCP_TRANSPORT=stdio

# HTTP Transport Settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=127.0.0.1

# HTTP Authentication (required for production HTTP deployments)
# Option 1: Simple API key
# MCP_API_KEY=your_secret_api_key

# Option 2: Microsoft Entra ID (Azure AD) OAuth
# ENTRA_ID_TENANT_ID=your_tenant_id
# ENTRA_ID_CLIENT_ID=your_app_registration_client_id
# ENTRA_ID_AUDIENCE=api://your_app_id

# Partner Mode (optional, for Toast partner integrations)
# PARTNER_MODE=false

# Webhook Configuration (optional, for future event ingestion)
# WEBHOOK_SECRET=your_webhook_secret_here
# WEBHOOK_PORT=3100

# Microsoft Teams Integration
# Power Automate workflow webhook URL (replaces deprecated incoming webhooks)
# MICROSOFT_TEAMS_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com/workflows/...
# MICROSOFT_BRIDGE_ENABLED=false
