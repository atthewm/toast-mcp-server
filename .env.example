# Toast API Credentials (required)
TOAST_CLIENT_ID=your_client_id_here
TOAST_CLIENT_SECRET=your_client_secret_here

# Toast Restaurant Configuration
# Single restaurant GUID (used if TOAST_RESTAURANT_GUIDS is not set)
TOAST_RESTAURANT_GUID=your_restaurant_guid_here
# Comma-separated list for multi-location support
# TOAST_RESTAURANT_GUIDS=guid1,guid2,guid3

# Toast API Host (defaults to production)
# TOAST_API_HOST=https://ws-api.toasttab.com

# Safety Controls
# Set to "true" to enable write operations (create/update/cancel orders)
ALLOW_WRITES=false
# Set to "true" to validate write payloads without executing them
DRY_RUN=true

# Logging
LOG_LEVEL=info

# Partner Mode (optional, for Toast partner integrations)
# PARTNER_MODE=false

# Webhook Configuration (optional, for future event ingestion)
# WEBHOOK_SECRET=your_webhook_secret_here
# WEBHOOK_PORT=3100

# Microsoft Teams Integration (optional, future use)
# MICROSOFT_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# MICROSOFT_BRIDGE_ENABLED=false
